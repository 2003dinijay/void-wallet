# MongoDB
MONGODB_URL=<your_mongodb_atlas_url>
DB_NAME=voidwallet

# JWT Auth
JWT_SECRET=pick-any-long-random-string-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Sepolia Testnet (Alchemy RPC)
ALCHEMY_URL=https://eth-sepolia.g.alchemy.com/v2/<your_alchemy_key>

# Counter contract address — set this after running deploy_counter.py
COUNTER_CONTRACT_ADDRESS=
